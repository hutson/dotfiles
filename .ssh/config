# Include the DevPod-managed SSH config file. The glob pattern silently matches
# no files if the file does not exist (e.g., on a fresh deploy before DevPod
# has been configured).
Include ~/.ssh/devpod*

Host *
	# Prevent network devices from silently dropping idle connections.
	ServerAliveInterval 60

	# Easier to visualize keys for verification than a fingerprint.
	VisualHostKey yes

	# Prompt before adding keys to the agent to prevent a compromised remote
	# server from silently using forwarded credentials.
	AddKeysToAgent confirm

	# Obfuscate connection history in `known_hosts` if the file is compromised.
	HashKnownHosts yes
